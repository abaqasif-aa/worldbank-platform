# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=worldbank
POSTGRES_USER=de
POSTGRES_PASSWORD=de

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# MLflow
MLFLOW_BACKEND_STORE_URI=sqlite:////mlflow/artifacts/mlflow.db
MLFLOW_DEFAULT_ARTIFACT_ROOT=/mlflow/artifacts
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_TRACKING_USERNAME=your_name_here

# World Bank API
WB_BASE_URL=https://api.worldbank.org/v2
WB_START_YEAR=2000
WB_END_YEAR=2023
RAW_DIR=/app/data/raw

# Ollama (local LLM — runs on host machine, not in Docker)
# Install from https://ollama.com then run: ollama pull llama3.1:8b-instruct-q4_0
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_MODEL=llama3.1:8b-instruct-q4_0
